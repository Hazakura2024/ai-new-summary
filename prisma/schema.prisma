generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url や directUrl は絶対に書かない！
}

// 要約データを保存するモデル
model Summary {
  id        String   @id @default(cuid())
  sourceUrl String
  title     String?
  content   String
  createdAt DateTime @default(now())

  @@index([createdAt])
}